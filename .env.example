ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
PORT=3000

# =========================================================
# 画像自動生成（DALL-E 3 / text-embedding-3-small）
# 未設定だと画像生成・セマンティック重複排除がスキップされる
# =========================================================
OPENAI_API_KEY=

# =========================================================
# X (Twitter) API — 店舗（store / @pita_pizza1）の自動投稿・計測用
# https://developer.x.com/ でアプリ登録→キー発行（Read and Write）
# AI総合・セミナー用は別アプリでキー追加→コード側でアカウント別マッピング予定
# =========================================================
X_APP_KEY=
X_APP_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
X_BEARER_TOKEN=

# =========================================================
# 簡易パスワード保護（Renderデプロイ時は必須推奨）
# =========================================================
APP_USER=kotaro
APP_PASSWORD=

# =========================================================
# 為替レート（コスト表示用。月1くらいで最新値に調整）
# =========================================================
USD_JPY=150

# =========================================================
# SQLite DBファイルパス（未指定時は ./data.sqlite）
# =========================================================
DB_PATH=
# ローカル手動で SQLite コピー: npm run data:backup（backups/ は git 対象外）

# =========================================================
# アフィリエイト／誘導先URL（発行済みから順次埋める）
# 空のままでもOK（その場合、記事内URLはAIが自然文で言及のみ）
# =========================================================
# Playwright（note ブラウザ自動化: プロファイル分離は playwright/.auth/*.json）
# npm run pw:install && npm run pw:auth:pitapizza
# HEADED=0 npm run pw:note:draft:dry:pitapizza  ← headless スクショのみ（PowerShell: $env:HEADED='0'）
# =========================================================
AFFI_NOTE_PROFILE=
AFFI_BRAIN_URL=
AFFI_RAKUTEN_URL=
AFFI_AMAZON_URL=
AFFI_SEMINAR_URL=
STORE_EC_URL=
